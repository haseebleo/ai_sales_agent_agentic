# ============================================================
# Trango Tech AI Sales Agent — Environment Configuration
# ============================================================

# ── Provider Selection ────────────────────────────────────────────────────────
# LLM: dual | openai | anthropic | ollama | gemini
# 'dual' = Ollama for Discovery/Qualification + Gemini for Recommendation/Closing
LLM_PROVIDER=dual
DUAL_LLM_ROUTING=true

# STT: deepgram | openai_whisper | assemblyai
STT_PROVIDER=deepgram

# TTS: cartesia | elevenlabs | openai_tts | deepgram_tts
TTS_PROVIDER=cartesia

# Vector store: chroma | qdrant
VECTOR_STORE=chroma

# ── OpenAI (fallback / embedding) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TTS_VOICE=nova

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# ── Ollama (self-hosted, M4 MacBook) — Discovery & Qualification states ───────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Google Gemini — Recommendation, Closing, Objection states ─────────────────
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyCeNM9vEP7BeVjR2kTcY24pV2QPNyxuQug
GEMINI_MODEL=gemini-2.5-flash

# ── Deepgram (STT + TTS fallback) ─────────────────────────────────────────────
# Get your key: https://console.deepgram.com/
DEEPGRAM_API_KEY=c0e9937c84d1b3f942efde0cf05f3d0c45f9abae
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ── Cartesia TTS ──────────────────────────────────────────────────────────────
# Get your key: https://play.cartesia.ai/
CARTESIA_API_KEY=sk_car_R8GfEbeobZdPz1C2mDga1Z
# "Sarah" neutral professional female (recommended):
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
CARTESIA_MODEL_ID=sonic-english

# ── ElevenLabs (legacy fallback TTS) ─────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── AssemblyAI ────────────────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=...

# ── LiveKit (Pipecat transport) ────────────────────────────────────────────────
# Create a free project at: https://cloud.livekit.io/
LIVEKIT_URL=wss://ai-sales-agent-gkqrpar4.livekit.cloud
LIVEKIT_API_KEY=APIb9bwQtmAXfHo
LIVEKIT_API_SECRET=LvoeEAeenkNNjeDZKhee9UqPR6a8wzaJK0ksuz2T12KK

# ── Vector Store: Chroma ──────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=trango_knowledge

# ── Vector Store: Qdrant ──────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=trango_knowledge

# ── RAG Settings ──────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
KB_FILE_PATH=./kb/knowledge_base.xlsx

# ── Lead Output ───────────────────────────────────────────────────────────────
LEADS_FILE_PATH=./data/leads.xlsx
LEAD_SHEET_NAME=LeadData

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_SECONDS=1800
MAX_HISTORY_TURNS=20

# ── Voice ─────────────────────────────────────────────────────────────────────
VAD_SILENCE_THRESHOLD_MS=800
BARGE_IN_ENABLED=true
AUDIO_SAMPLE_RATE=16000

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

